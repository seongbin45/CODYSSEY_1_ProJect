# 로컬: 복사 후 secrets.toml 로 저장
#   copy .streamlit\secrets.toml.example .streamlit\secrets.toml
#
# Streamlit Cloud: App settings → Secrets 에 동일 형식 붙여넣기
# (secrets.toml 은 git 에 올리지 마세요)

# --- 무료 권장 (우선 등록) ---
# Groq: https://console.groq.com
GROQ_API_KEY = "gsk_..."

# OpenRouter 무료 모델: https://openrouter.ai
# OPENROUTER_API_KEY = "sk-or-..."

# --- OpenAI ChatGPT API (유료/크레딧) ---
# https://platform.openai.com/api-keys
# OPENAI_API_KEY = "sk-..."

# --- Gemini (지역/쿼터 이슈 시 Fallback이 Groq로 전환) ---
# GEMINI_API_KEY = "..."

# --- 기타 OpenAI 호환 (Grok 등) ---
# CUSTOM_API_KEY = "..."
# OPENAI_BASE_URL 은 앱 사이드바에서 설정 가능
